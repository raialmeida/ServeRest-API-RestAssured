{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "produtos",
    "precoTotal",
    "quantidadeTotal",
    "idUsuario",
    "_id"
  ],
  "properties": {
    "produtos": {
      "type": "array"
    },
    "precoTotal": {
      "type": "integer"
    },
    "quantidadeTotal": {
      "type": "integer"
    },
    "idUsuario": {
      "type": "string"
    },
    "_id": {
      "type": "string"
    }
  }
}