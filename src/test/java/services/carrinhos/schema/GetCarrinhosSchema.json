{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "quantidade",
    "carrinhos"
  ],
  "additionalProperties": false,
  "properties": {
    "quantidade": {
      "type": "integer",
      "minimum": 0
    },
    "carrinhos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "produtos",
          "precoTotal",
          "quantidadeTotal",
          "idUsuario",
          "_id"
        ],
        "additionalProperties": false,
        "properties": {
          "produtos": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "idProduto",
                "quantidade",
                "precoUnitario"
              ],
              "additionalProperties": false,
              "properties": {
                "idProduto": {
                  "type": "string",
                  "minLength": 1
                },
                "quantidade": {
                  "type": "integer",
                  "minimum": 1
                },
                "precoUnitario": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          },
          "precoTotal": {
            "type": "integer",
            "minimum": 0
          },
          "quantidadeTotal": {
            "type": "integer",
            "minimum": 0
          },
          "idUsuario": {
            "type": "string",
            "minLength": 1
          },
          "_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}