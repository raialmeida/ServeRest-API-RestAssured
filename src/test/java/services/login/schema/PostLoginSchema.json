{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "message",
    "authorization"
  ],
  "additionalProperties": false,
  "properties": {
    "message": {
      "type": "string",
      "minLength": 1
    },
    "authorization": {
      "type": "string",
      "pattern": "^Bearer\\s+.+$"
    }
  }
}